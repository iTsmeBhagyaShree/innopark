# Use Railway when local backend is not running (avoids ERR_CONNECTION_REFUSED on localhost).
VITE_API_BASE_URL=https://inopark-demo-production.up.railway.app
VITE_API_URL=https://inopark-demo-production.up.railway.app/api/v1

# Local API (start backend: cd backend && npm run dev)
# VITE_API_BASE_URL=http://localhost:8010
# VITE_API_URL=http://localhost:8010/api/v1

# PWA Configuration
VITE_PWA_ENABLED=true